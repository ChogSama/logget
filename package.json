{
  "name": "logget",
  "private": true,
  "version": "0.0.1",
  "description": "AI-powered Micro-Journaling for Student Well-Being",
  "keywords": [],
  "homepage": "https://github.com/ChogSama/vital-log#readme",
  "bugs": {
    "url": "https://github.com/ChogSama/vital-log/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChogSama/vital-log.git"
  },
  "license": "ISC",
  "author": "ChogSama<ChogSama> and Doman<do-manh-hiep>",
  "contributors": [],
  "type": "module",
  "scripts": {
    "setup": "node setup.js",
    "dev:web": "cd web && vite --host",
    "dev:server": "cross-env PYTHONPATH=. PYTHONIOENCODING=utf-8 uv run fastapi dev server/main.py",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "build:web": "cd web && tsc -b && vite build",
    "lint:web": "cd web && eslint .",
    "lint:server": "cross-env PYTHONPATH=. uv run ruff check server/",
    "db:migrate": "cross-env PYTHONPATH=. uv run alembic -c server/alembic.ini upgrade head",
    "db:revision": "cross-env PYTHONPATH=. uv run alembic -c server/alembic.ini revision --autogenerate -m"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.2",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "input-otp": "^1.4.2",
    "lodash": "^4.18.1",
    "lucide-react": "^1.16.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.78.0",
    "react-router-dom": "^7.15.1",
    "sonner": "^2.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.4.38",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
}
